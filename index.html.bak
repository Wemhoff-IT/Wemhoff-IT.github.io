<!DOCTYPE html>
<html lang="de-DE">
	<head>
		<meta charset="utf-8">
		<title>JavaScript</title>	
		<link rel="stylesheet" href="./index.css">		
	</head>
	<body>
	
		<h1 class="center">Benzinpreisrechner</h1>

		<script>
		
		let liter = parseFloat(window.prompt("Wie viel Liter Treibstoff möchten Sie tanken?").trim());
			
		// check if value is number
		if(liter != "NaN" && liter > 0)
		{
			let fuel = window.prompt("Welche Art Treibstoff möchten Sie tanken?").trim();

			// check for possible fuels
			if(fuel == "Diesel" || fuel == "Super" || fuel == "E10" )
			{
				let calc;		
				
				// calculate and fix float multiplication error
				if(fuel == "Diesel") calc = (liter * 1.74).toFixed(2)
				if(fuel == "Super") calc = (liter * 1.82).toFixed(2)
				if(fuel == "E10") calc = (liter * 1.78).toFixed(2)
				
				document.write("<h2 class='center'>Vielen Dank</h2><br>").element.classList.add("center");			
				document.write("<p>Sie Tanken: " + liter + " Liter " + fuel + ".</p><br>").element.classList.add("center");
				document.write("<p>Die Gesamtsumme beträgt: " + calc + " €</p>").element.classList.add("center");			
			}
			else
			{	
				document.write("<p>Bitte die Treibstoffangabe überprüfen. Mögliche Treibstoffarten sind Diesel, Super oder E10.</p>").element.classList.add("center");			
			}
		}
		else
		{
			document.write("<p>Bitte nur Zahlen größer 0 bei der Literangabe, bitte Eingabe überprüfen.</p>").element.classList.add("center");
		}

		</script>
	</body>
</html>
